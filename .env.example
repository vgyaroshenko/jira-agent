JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_jira_api_token
# Используется планировщиком и как fallback для создания бага без --related
# Можно указать несколько через запятую: GN,CCW,DEV
JIRA_PROJECT_KEY=GN,CCW,DEV

# Язык для каждого проекта: UA, RU или EN
# Используется при генерации тест-кейсов и баг-репортов
# Если не указан — язык определяется по заголовку задачи
PROJECT_LANG_GN=UA
PROJECT_LANG_CCW=EN
PROJECT_LANG_STRDRNK1=RU
